{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teamObservability": {
    "enabled": true,
    "logPath": "logs/",
    "autoSnapshot": true,
    "snapshotTriggers": ["TASK_START", "TASK_COMPLETE", "INTERVENTION", "TURN_END"],
    "interventionPoints": ["BEFORE_TASK", "AFTER_FAILURE", "MANUAL_APPROVAL"],
    "conversationLog": true,
    "changeTracking": true
  }
}
